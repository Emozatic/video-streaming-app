<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>HOME</h1>
    <%for(let video of allVideos){%>
        <p><%=video.title%></p>
        <img src="<%=video.thumbnail%>" alt="thumbnails">
        <form action="/home/show/<%=video._id%>" method="GET">
            <button>Show</button>
        </form>

        <%}%>
</body>
</html>