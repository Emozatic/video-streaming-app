<% layout("/layouts/boilerplate") %>
    <form action="/home/<%=videoDetails._id%>?_method=PUT" method="POST">
    <h1>Edit Your Video's Details</h1>
    <label for="title"></label>
    <input type="text" value="<%=videoDetails.title%>" name="edit[title]"> 

     <label for="description"></label>
    <input type="text" value="<%=videoDetails.description%>" name="edit[description]"> 

     <label for="edit[thumbnail]"></label>
    <input type="url" name="edit[thubnail]"value="<%=videoDetails.thumbnail%>">

    <button>Edit</button>
    </form>
